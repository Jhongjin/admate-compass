# Rename this file to `.env.local` for local Next.js development.
# Production and preview values are managed in Vercel environment variables, not in vercel.json.

# Public app URLs and browser-safe keys.
NEXT_PUBLIC_SITE_URL=<COMPASS_PUBLIC_URL>
NEXT_PUBLIC_SUPABASE_URL=<SUPABASE_PROJECT_URL>
NEXT_PUBLIC_SUPABASE_ANON_KEY=<SUPABASE_PUBLIC_ANON_KEY>

# Server-only Supabase / document store settings. Do not expose these as NEXT_PUBLIC_* values.
SUPABASE_SERVICE_ROLE_KEY=<SERVER_ONLY_SUPABASE_SERVICE_ROLE_KEY>
COMPASS_DB_SCHEMA=compass
EMBEDDING_DIM=1024

# Compass answer LLM provider boundary.
# Leave empty for production auto selection: OpenRouter key -> OpenRouter, OpenAI key -> OpenAI, otherwise Ollama.
# Pin this value only when you intentionally need a specific provider: openrouter, openai, or ollama.
COMPASS_ANSWER_PROVIDER=
COMPASS_ANSWER_MODELS=<OPENROUTER_MODEL_FALLBACKS_COMMA_SEPARATED>
COMPASS_ANSWER_TEMPERATURE=0.1
COMPASS_ANSWER_TOP_P=0.85
COMPASS_ANSWER_MAX_TOKENS=1200
COMPASS_ANSWER_TIMEOUT_MS=15000
COMPASS_REMOTE_ANSWER_TIMEOUT_MS=30000
COMPASS_RETRIEVAL_TIMEOUT_MS=30000
COMPASS_RETRIEVAL_CHANNEL_TIMEOUT_MS=28000

# Server-only OpenRouter settings. Do not expose these as NEXT_PUBLIC_* values.
OPENROUTER_API_KEY=<SERVER_ONLY_OPENROUTER_API_KEY>
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_HTTP_REFERER=<COMPASS_PUBLIC_URL>
OPENROUTER_APP_TITLE=AdMate Compass

# Server-only OpenAI fallback settings.
OPENAI_API_KEY=<SERVER_ONLY_OPENAI_API_KEY>
OPENAI_IDEA_MODEL=gpt-4o-mini

# Server-only Ollama/local fallback settings.
OLLAMA_BASE_URL=<SERVER_ONLY_OLLAMA_BASE_URL>
OLLAMA_DEFAULT_MODEL=mistral:7b
COMPASS_OLLAMA_ANSWER_TIMEOUT_MS=30000
VULTR_OLLAMA_URL=

# Optional legacy Gemini helpers.
GOOGLE_API_KEY=<SERVER_ONLY_GOOGLE_API_KEY>
GOOGLE_MODEL=gemini-1.5-flash

# Compass Evidence Graph / GraphRAG gates.
COMPASS_EVIDENCE_GRAPH_ENABLED=false
COMPASS_OFFICIAL_GUIDE_GRAPH_INDEXING_ENABLED=false
COMPASS_EVIDENCE_GRAPH_FOCUSED_RPC_ENABLED=false

# Compass retrieval caching.
# Memory caches are always fail-open; durable cache requires the retrieval_response_cache migration.
COMPASS_SUPABASE_ROWS_CACHE_TTL_MS=300000
COMPASS_FOCUSED_PRODUCT_GRAPH_RPC_CACHE_TTL_MS=300000
COMPASS_DURABLE_RETRIEVAL_CACHE_ENABLED=true
COMPASS_DURABLE_RETRIEVAL_CACHE_READ_TIMEOUT_MS=700
COMPASS_DURABLE_RETRIEVAL_CACHE_WRITE_TIMEOUT_MS=1200
COMPASS_DURABLE_RETRIEVAL_CACHE_HIT_WRITE_TIMEOUT_MS=700

# Core/Sentinel SSO handoff.
# Product handoff and session secrets are server-only. Do not expose them as NEXT_PUBLIC_* values.
ADMATE_CORE_AUTH_START_URL=https://sentinel.admate.ai.kr/auth/product/start
ADMATE_CORE_HANDOFF_REDEEM_URL=https://sentinel.admate.ai.kr/api/auth/handoff/redeem
ADMATE_COMPASS_HANDOFF_SECRET=<SERVER_ONLY_COMPASS_HANDOFF_SECRET>
ADMATE_COMPASS_SESSION_SECRET=<SERVER_ONLY_COMPASS_SESSION_COOKIE_SECRET>

# Compass source proposal queue boundary.
# Read-only queue status may be enabled without enabling queue writes.
COMPASS_SOURCE_PROPOSAL_QUEUE_READ_ENABLED=false
COMPASS_SOURCE_PROPOSAL_QUEUE_ENABLED=false
