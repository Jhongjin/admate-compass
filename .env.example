# Rename this file to `.env.local` to use environment variables locally with `next dev`
# https://nextjs.org/docs/app/building-your-application/configuring/environment-variables
MY_HOST="example.com"

# Compass answer LLM provider boundary.
# Leave empty for production auto selection: OpenRouter key -> OpenRouter, OpenAI key -> OpenAI, otherwise Ollama.
# Pin this value only when you intentionally need a specific provider: openrouter, openai, or ollama.
COMPASS_ANSWER_PROVIDER=
COMPASS_ANSWER_MODELS=<OPENROUTER_MODEL_FALLBACKS_COMMA_SEPARATED>
COMPASS_ANSWER_TEMPERATURE=0.1
COMPASS_ANSWER_TOP_P=0.85
COMPASS_ANSWER_MAX_TOKENS=1200
COMPASS_ANSWER_TIMEOUT_MS=15000
COMPASS_REMOTE_ANSWER_TIMEOUT_MS=15000
COMPASS_RETRIEVAL_TIMEOUT_MS=22000
COMPASS_RETRIEVAL_CHANNEL_TIMEOUT_MS=11000

# Server-only OpenRouter settings. Do not expose these as NEXT_PUBLIC_* values.
OPENROUTER_API_KEY=<SERVER_ONLY_OPENROUTER_API_KEY>
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_HTTP_REFERER=<COMPASS_PUBLIC_URL>
OPENROUTER_APP_TITLE=AdMate Compass

# Core/Sentinel SSO handoff.
# Product handoff and session secrets are server-only. Do not expose them as NEXT_PUBLIC_* values.
NEXT_PUBLIC_SITE_URL=<COMPASS_PUBLIC_URL>
ADMATE_CORE_AUTH_START_URL=https://sentinel.admate.ai.kr/auth/product/start
ADMATE_CORE_HANDOFF_REDEEM_URL=https://sentinel.admate.ai.kr/api/auth/handoff/redeem
ADMATE_COMPASS_HANDOFF_SECRET=<SERVER_ONLY_COMPASS_HANDOFF_SECRET>
ADMATE_COMPASS_SESSION_SECRET=<SERVER_ONLY_COMPASS_SESSION_COOKIE_SECRET>

# Compass source proposal queue boundary.
# Read-only queue status may be enabled without enabling queue writes.
COMPASS_SOURCE_PROPOSAL_QUEUE_READ_ENABLED=false
COMPASS_SOURCE_PROPOSAL_QUEUE_ENABLED=false
