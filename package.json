    "smoke:chat-ollama-local": "node scripts/smoke-chat-ollama-local.mjs",
    "gate6c:dry-run": "node scripts/gate6c-local-import-runner.mjs",
    "verify:harness": "node scripts/check-rag-contract.mjs && npm run check:compass-evidence-contract && npm run check:compass-chunking-contract && npm run check:compass-source-ops-contract && npm run check:rag-source-quality:sample && node scripts/evaluate-rag-fixtures.mjs && node scripts/check-nodata-boundary-fixtures.mjs && node scripts/check-compass-evidence-qa-fixtures.mjs && npm run check:compass-qa-evidence-prompt-visible && node scripts/check-compass-chat-ui-state-contract-fixtures.mjs && npm run check:compass-dev-fixture-renderer && npm run check:compass-source-panel-rendering && node scripts/check-admin-debug-surface.mjs",
    "verify:migration": "node scripts/check-compass-schema-readiness.mjs && node scripts/check-compass-table-references.mjs && node scripts/smoke-compass-rag-contract.mjs && node scripts/check-migration-env.mjs"
  },
