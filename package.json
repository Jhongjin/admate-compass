    "check:nodata-boundary": "node scripts/check-nodata-boundary-fixtures.mjs",
    "check:compass-evidence-qa": "node scripts/check-compass-evidence-qa-fixtures.mjs",
    "check:compass-qa-evidence-prompt-visible": "node scripts/check-compass-qa-evidence-prompt-visible.mjs",
